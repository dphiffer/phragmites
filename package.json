{
	"name": "phragmites",
	"version": "0.0.1",
	"description": "WordPress artist portfolio theme",
	"main": "index.js",
	"scripts": {
		"dist:mkdir": "mkdir -p dist",
		"dist:source-sans": "cp -r node_modules/source-sans dist/",
		"scss:build": "sass assets/scss/main.scss:dist/main.css assets/scss/blocks.scss:dist/blocks.css",
		"scss:watch": "sass --watch assets/scss:dist",
		"start": "npm-run-all dist:* watch",
		"watch": "webpack --watch",
		"build": "webpack"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dphiffer/phragmites.git"
	},
	"keywords": [
		"wordpress",
		"theme",
		"portfolio"
	],
	"author": "Dan Phiffer <dan@phiffer.org>",
	"license": "GPLv3",
	"bugs": {
		"url": "https://github.com/dphiffer/phragmites/issues"
	},
	"homepage": "https://github.com/dphiffer/phragmites#readme",
	"type": "module",
	"devDependencies": {
		"css-loader": "^6.7.1",
		"file-loader": "^6.2.0",
		"npm-run-all": "^4.1.5",
		"sass": "^1.54.5",
		"sass-loader": "^13.0.2",
		"style-loader": "^3.3.1",
		"ts-loader": "^9.3.1",
		"typescript": "^4.8.2",
		"webpack": "^5.74.0",
		"webpack-cli": "^4.10.0"
	},
	"dependencies": {
		"scrollama": "^3.2.0",
		"source-sans": "^3.46.0"
	}
}
